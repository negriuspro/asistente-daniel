# ── Puerto público de Jarvis ─────────────────────────────────────────────────
APP_PORT=3000

# ── IA (requerido) ───────────────────────────────────────────────────────────
# Obtén tu key GRATIS en: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Voz ElevenLabs (opcional) ────────────────────────────────────────────────
# Sin esto Jarvis usa pyttsx3 + espeak (gratis, calidad menor).
# Plan gratuito: 10 000 chars/mes — https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# ── Smart Home — Tuya / Smart Life ───────────────────────────────────────────
# Credenciales en: https://iot.tuya.com → Cloud → Project → Authorization Key
# TUYA_ENDPOINT: tuyaeu.com (Europa) | tuyaus.com (USA) | tuyacn.com (China)
TUYA_ACCESS_ID=tu_access_id_aqui
TUYA_ACCESS_SECRET=tu_access_secret_aqui
TUYA_ENDPOINT=https://openapi.tuyaeu.com

# ID del enchufe que controla la carga de la laptop/PC (dejar vacío si no aplica)
TUYA_PLUG_PC_ID=

# Lista de dispositivos Tuya: "Nombre:device_id,Nombre2:device_id2"
TUYA_DEVICES=Luz led:DEVICE_ID_1,Aire acondicionado:DEVICE_ID_2,Control remoto:DEVICE_ID_3,Enchufe PC:DEVICE_ID_4

# ── Monitor de batería ───────────────────────────────────────────────────────
# Solo aplica si Jarvis controla el enchufe de carga de un portátil.
BATTERY_LOW=20
BATTERY_HIGH=80

# ── Google Home / Chromecast ─────────────────────────────────────────────────
# IP local del altavoz Google Home o Chromecast.
GOOGLE_HOME_HOST=
GOOGLE_HOME_PORT=8009

# ── Docker control API ───────────────────────────────────────────────────────
# Token de seguridad para los endpoints /api/docker/* — cámbialo siempre.
JARVIS_ADMIN_TOKEN=cambia-este-token-por-uno-largo-y-aleatorio

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Docker internos ──────────────────────────────────────────────────────────
DOCKER_LOG_LINES=200
DOCKER_STOP_TIMEOUT=10

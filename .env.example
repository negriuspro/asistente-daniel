# Copia este archivo como .env y pon tu API key de Groq
# Obtén la key GRATIS en: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Voz (ElevenLabs) ────────────────────────────────────────────────
# Obtén la key en: https://elevenlabs.io  (plan gratuito: 10k chars/mes)
# Si no configuras esto, Jarvis usa pyttsx3 (voz del sistema, gratuita).
#
# Voz recomendada para Jarvis — Daniel (british, deep, cinematográfico):
#   ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
# Otras voces masculinas profesionales:
#   Adam (americano, profundo):    pNInz6obpgDQGcFmaJgB
#   Arnold (fuerte, americano):    VR6AewLTigWG4xSOukaG
# Para buscar más voces: https://elevenlabs.io/voice-library
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# ── Google Home / Nest (altavoz) ────────────────────────────────────
# IP local de tu Google Home o Nest speaker.
# Para encontrar la IP: abre la app Google Home → dispositivo → configuración → info del dispositivo
# El puerto es siempre 8009 (Chromecast protocol).
GOOGLE_HOME_HOST=
GOOGLE_HOME_PORT=8009

# ── Smart Home (Tuya / Smart Life) ──────────────────────────────────
# Obtén estas credenciales en: https://iot.tuya.com
# TUYA_ENDPOINT opciones: tuyaeu.com (Europa) | tuyaus.com (USA) | tuyacn.com (China)
TUYA_ACCESS_ID=tu_access_id_aqui
TUYA_ACCESS_SECRET=tu_access_secret_aqui
TUYA_ENDPOINT=https://openapi.tuyaeu.com
